<?xml version="1.0" encoding="utf-8"?>
<!-- 主界面布局：顶部搜索栏+Tab + 中间歌曲列表 + 底部播放控制栏 -->
<!-- 同时适配 TV（遥控器）和手机（触屏）：尺寸通过 @dimen 引用，按 sw360dp/sw600dp 自动切换 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1A1A1A"
    android:fitsSystemWindows="true">

    <!-- 顶部区域：搜索框 + Tab -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/item_padding"
        android:background="#FF212121">

        <!-- 搜索框 + 设置按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/search_bar_height"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#FF303030"
                android:padding="@dimen/item_padding"
                android:layout_marginBottom="@dimen/item_padding">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_search"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="搜索" />

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="输入歌曲名、歌手名搜索..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#88FFFFFF"
                    android:textSize="@dimen/tab_text_size"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"
                    android:padding="@dimen/item_padding"
                    android:focusable="true"
                    android:focusableInTouchMode="true" />

                <ImageView
                    android:id="@+id/iv_settings"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_settings"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="设置"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tab 切换 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/tab_search"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="搜索"
                android:textColor="#FFFFC107"
                android:textSize="@dimen/tab_text_size"
                android:textStyle="bold"
                android:padding="@dimen/tab_padding"
                android:background="@drawable/focus_background"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true" />

            <TextView
                android:id="@+id/tab_rank"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="排行"
                android:textColor="#CCFFFFFF"
                android:textSize="@dimen/tab_text_size"
                android:padding="@dimen/tab_padding"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true" />

            <TextView
                android:id="@+id/tab_mine"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="我的"
                android:textColor="#CCFFFFFF"
                android:textSize="@dimen/tab_text_size"
                android:padding="@dimen/tab_padding"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true" />

            <TextView
                android:id="@+id/tab_settings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="音源"
                android:textColor="#CCFFFFFF"
                android:textSize="@dimen/tab_text_size"
                android:padding="@dimen/tab_padding"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- 中间：歌曲列表区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/item_padding"
            android:clipToPadding="false"
            android:scrollbars="vertical" />

        <!-- 空状态提示 -->
        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#99FFFFFF"
            android:textSize="@dimen/song_title_size"
            android:gravity="center"
            android:text="请输入关键词搜索音乐"
            android:visibility="visible" />

        <!-- 加载进度条 -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

    <!-- 状态提示 -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/item_padding"
        android:textColor="#AAFFFFFF"
        android:textSize="@dimen/song_singer_size"
        android:gravity="center"
        android:visibility="gone"
        android:background="#FF212121" />

    <!-- 底部播放控制栏 -->
    <include
        android:id="@+id/player_bar"
        layout="@layout/view_player_bar" />

</LinearLayout>
